{
  "name": "geohouse",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:frontend": "vite --host 127.0.0.1",
    "dev:api": "python -m uvicorn main:app --reload --host 127.0.0.1 --port 8000 --app-dir backend",
    "dev:full": "concurrently -k -n FRONTEND,API -c blue,green \"npm run dev:frontend\" \"npm run dev:api\"",
    "setup:api": "python -m pip install -r backend/requirements.txt"
  },
  "dependencies": {
    "bootstrap": "^5.3.0",
    "leaflet": "^1.9.4",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "vite": "^5.0.0",
    "concurrently": "^8.2.2"
  }
}
